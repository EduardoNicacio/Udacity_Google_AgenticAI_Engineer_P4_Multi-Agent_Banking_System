---
config:
  layout: elk
  theme: mc
---
flowchart TB
 subgraph DepositAgent["Deposit Agent"]
        DB1[("MySQL accounts table")]
        D["Deposit A2A Call"]
        DB2[("MySQL balance query")]
        DB3[("MySQL transactions query")]
        DB4[("Sum of balances > target?")]
  end
 subgraph LoanAgent["Loan Agent"]
        DB5[("MySQL loans.outstanding_balance")]
        L["Loan Agent via A2A"]
        DB6[("Full loan record")]
        DB7[("Next payment date")]
  end
 subgraph InfoGathering["Info Gathering - Parallel"]
        OB["OutstandingBalance"]
        DS1[("Vertex AI Search results")]
        PA["PolicyAgent"]
        DS2[("Customer profile snippets")]
        UP["UserProfileAgent"]
  end
    U["User"] -- Send Query --> W["ADK Web UI"]
    W -- Select Agent --> M["Manager Agent"]
    M -- Intent Analysis --> M1{"Is it a Deposit query?"}
    M1 -- Yes --> D
    M1 -- No --> LQ{"Is it a Loan application?"}
    LQ -- Yes --> L
    LQ -- No --> G["Manager handles general banking question"]
    D -- Tool: get_accounts --> DB1
    D -- Tool: get_balance --> DB2
    D -- Tool: get_transactions --> DB3
    D -- Tool: check_minimum_balance --> DB4
    L -- Tool: get_loan_balance --> DB5
    L -- Tool: get_loan_details --> DB6
    L -- Tool: get_next_payment_date --> DB7
    L --> LA1["GetRequestedValue"]
    LA1 --> LA2["InfoGathering Parallel"]
    OB -- Tool: get_loan_balance --> DB5
    PA -- Tool: datastore_search_tool --> DS1
    UP -- Tool: datastore_search_tool --> DS2
    LA2 --> LA3["TotalValueAgent"]
    OB -- outstanding_balance --> LA3
    PA -- policy_criteria --> LA3
    LA3 --> LA4["CheckEquity"]
    LA4 -- "Sub-agent: deposit A2A" --> D
    D -- check_minimum_balance --> LA4
    LA4 --> LA5["FinalDecision"]
    UP -- customer_profile --> LA5
    LA5 -- final_decision_result --> M

     DB1:::database
     D:::agent
     DB2:::database
     DB3:::database
     DB4:::database
     DB5:::database
     L:::agent
     DB6:::database
     DB7:::database
     OB:::process
     DS1:::database
     PA:::process
     DS2:::database
     UP:::process
     M:::agent
     M1:::decision
     LQ:::decision
     G:::process
     LA1:::agent
     LA3:::agent
     LA4:::agent
     LA5:::agent
    classDef agent fill:#eef2ff,stroke:#818cf8,stroke-width:2px,color:#1e1b4b
    classDef database fill:#f0fdfa,stroke:#2dd4bf,stroke-width:2px,color:#1e1b4b
    classDef decision fill:#fdf4ff,stroke:#e879f9,stroke-width:2px,color:#1e1b4b
    classDef process fill:#fff7ed,stroke:#fb923c,stroke-width:2px,color:#1e1b4b