# ========================================
# Google Cloud Configuration
# ========================================
GOOGLE_APPLICATION_CREDENTIALS=
CREDENTIALS=
PROJECT_ID=
LOCATION=us-central1

GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI Search (RAG)
DATASTORE_ENGINE_ID=
DATASTORE_PROJECT_ID=
DATASTORE_LOCATION=global

# Toolbox URL
TOOLBOX_URL=http://127.0.0.1:5000

# MySQL for MCP Toolbox (Local MySQL - Cloud SQL not available in lab)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mysql-user
MYSQL_PASSWORD=mysql-password

# ========================================
# MODEL CONFIGURATION
# ========================================

# Global Gemini model (default: gemini-2.5-flash; rubric asks for tests with gemini-2.5-pro, gemini-2.5-flash, and gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash
